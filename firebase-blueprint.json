{
  "entities": {
    "User": {
      "title": "User",
      "description": "Uygulama kullanıcısı profili.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["otuken", "gok", "gece"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Log": {
      "title": "Log",
      "description": "Sistem ve bağlantı günlükleri.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "msg": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warn", "error", "sys"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "msg", "type", "timestamp"]
    },
    "Connection": {
      "title": "Connection",
      "description": "Uzak masaüstü bağlantı kayıtları.",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["callerId", "receiverId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Kullanıcı profilleri."
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "Sistem günlükleri."
    },
    "/connections/{connectionId}": {
      "schema": "Connection",
      "description": "Bağlantı oturumları."
    }
  }
}
